# Neon Postgres — cadena de conexión con soporte de pooling (usada tanto por
# el driver neon-serverless/Pool como por neon-http para el adapter de Auth.js)
DATABASE_URL=

# Auth.js v5
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# SMTP (magic link + emails transaccionales). Con Gmail: activa verificación
# en 2 pasos en la cuenta y genera una "contraseña de aplicación" en
# https://myaccount.google.com/apppasswords — no uses la contraseña normal.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="LlamaEats <tu-correo@gmail.com>"

# Vercel Blob (fotos de restaurantes y platos)
BLOB_READ_WRITE_TOKEN=

# Número de WhatsApp Business para el botón de soporte, formato E.164 sin "+"
# (ej. 51987654321). Si se deja vacío, el botón flotante no se muestra.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Cron de expiración de reservas sin pagar
CRON_SECRET=

# Verificación automática de RUC vía SUNAT (apis.net.pe u otro proveedor
# compatible). Sin este token, el alta de restaurantes sigue funcionando
# pero queda solo con revisión manual del admin (sin autocompletar razón
# social/estado). Token gratuito en https://apis.net.pe
RUC_LOOKUP_API_TOKEN=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Proveedor de pago activo (interfaz PaymentProvider). "fake" en desarrollo.
PAYMENT_PROVIDER=fake

# Usuarios demo para el script de seed (deben coincidir con el correo con el
# que inicies sesión por Google/magic link para "entrar" a cada rol demo)
SEED_ADMIN_EMAIL=admin@example.com
SEED_OWNER_EMAIL=owner@example.com
SEED_CLIENT_EMAIL=client@example.com
